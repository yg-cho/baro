# Server
PORT=8000
WEB_ORIGIN=http://localhost:3000

# Database — leave DATABASE_URL unset to use embedded PGlite (.baro/pglite)
# DATABASE_URL=postgres://user:pass@localhost:5432/baro
# PGLITE_DATA_DIR=.baro/pglite

# Auth — generate a real secret: openssl rand -base64 32
BETTER_AUTH_SECRET=baro-dev-secret-change-me
BETTER_AUTH_URL=http://localhost:8000

# Social login (optional — buttons appear automatically when keys are set)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
